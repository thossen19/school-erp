APP_NAME=AiSchool ERP
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
APP_TIMEZONE=Asia/Dhaka

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration (MySQL 8)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aischool
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Session Configuration
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Cache Configuration
CACHE_STORE=redis
# CACHE_STORE=file
CACHE_PREFIX=aischool_cache_

# Redis Configuration
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB_CACHE=1
REDIS_DB_SESSION=2
REDIS_DB_QUEUE=3

# Queue Configuration
QUEUE_CONNECTION=database
# QUEUE_CONNECTION=redis

# Broadcast Configuration
BROADCAST_CONNECTION=log

# Filesystem Configuration
FILESYSTEM_DISK=local
FILESYSTEM_CLOUD=s3

# Mail Configuration
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@aischool.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 / Cloud Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=
AWS_ENDPOINT=

# Laravel Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:8000,localhost:8080
SANCTUM_TOKEN_EXPIRATION=1440
SANCTUM_TOKEN_PREFIX=aischool_

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# School-Specific Settings
SCHOOL_NAME=My School
SCHOOL_CODE=SCH001
SCHOOL_ADDRESS=
SCHOOL_PHONE=
SCHOOL_EMAIL=
SCHOOL_WEBSITE=
SCHOOL_LOGO=
SCHOOL_TIMEZONE=Asia/Dhaka
SCHOOL_LOCALE=en
SCHOOL_MULTI_TENANT=true
SCHOOL_CURRENCY=BDT
SCHOOL_CURRENCY_SYMBOL=৳
SCHOOL_CACHE_TTL=3600

# Admission Settings
SCHOOL_ADMISSION_ONLINE=true
SCHOOL_REGISTRATION_FEE=500

# Fee & Payment Settings
SCHOOL_ENABLE_ONLINE_PAYMENT=true
SCHOOL_ENABLE_PARTIAL_PAYMENT=true
SCHOOL_ENABLE_INSTALLMENT=true
SCHOOL_LATE_FEE_PER_DAY=10
SCHOOL_LATE_FEE_AFTER_DAYS=15
SCHOOL_MAX_INSTALLMENTS=4

# Attendance Settings
SCHOOL_ATTENDANCE_METHOD=daily
SCHOOL_ENABLE_BIOMETRIC=false
SCHOOL_ENABLE_FACE_RECOGNITION=false
SCHOOL_ENABLE_GEOLOCATION=false

# Grade Settings
SCHOOL_GRADE_SYSTEM=percentage
SCHOOL_PASS_PERCENTAGE=33

# Fee Payment Gateways
# SSLCommerz (Bangladesh)
SSLC_STORE_ID=
SSLC_STORE_PASSWORD=
SSLC_SANDBOX=true

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_SANDBOX=true

# bKash (Bangladesh)
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_SANDBOX=true

# SMS Configuration
SMS_PROVIDER=twilio
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# WhatsApp / Vonage
VONAGE_KEY=
VONAGE_SECRET=
VONAGE_FROM=

# GPS / Vehicle Tracking
GOOGLE_MAPS_API_KEY=
GPS_TRACKING_INTERVAL_SECONDS=30
GPS_TRACKING_ENABLED=false

# Push Notifications
FCM_SERVER_KEY=
FCM_SENDER_ID=

# Exam Settings
SCHOOL_ALLOW_REEVALUATION=true
SCHOOL_REEVALUATION_FEE=500

# Library Settings
SCHOOL_LIBRARY_FINE_PER_DAY=5

# Feature Flags
FEATURE_ONLINE_ADMISSION=true
FEATURE_ONLINE_FEE_PAYMENT=true
FEATURE_BIOMETRIC_ATTENDANCE=false
FEATURE_SMS_NOTIFICATION=false
FEATURE_EMAIL_NOTIFICATION=true
FEATURE_WHATSAPP_NOTIFICATION=false
FEATURE_GPS_TRACKING=false
FEATURE_FACE_RECOGNITION=false
FEATURE_BULK_SMS=false
FEATURE_BULK_EMAIL=true
FEATURE_AUTO_FEE_REMINDER=true
FEATURE_PARENT_PORTAL=true
FEATURE_STUDENT_PORTAL=true
FEATURE_TEACHER_PORTAL=true

# Module Status
SCHOOL_ENABLE_PAYROLL=true
SCHOOL_ENABLE_TRANSPORT=true
SCHOOL_ENABLE_HOSTEL=false

# Notification Settings
SCHOOL_ENABLE_SMS=false
SCHOOL_ENABLE_PUSH=true
SCHOOL_SMS_PROVIDER=twilio
SCHOOL_SMS_API_KEY=
SCHOOL_SMS_SENDER_ID=SCHOOL

# Vite
VITE_APP_NAME="${APP_NAME}"
VITE_SANCTUM_URL="${APP_URL}"
